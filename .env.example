# Use either DATABASE_URL or SUPABASE_DB_URL for Supabase/Postgres
# Example format:
# postgres://username:password@dbname.cajdhxzpemaiahtdzhna.supabase.co:5432/postgres
DATABASE_URL=
# or
SUPABASE_DB_URL=

# Flask secret key for sessions
SECRET_KEY=change-this-secret-key

# Optional: local SQLite fallback path
SQLITE_DB_PATH=./netflix_app.db
